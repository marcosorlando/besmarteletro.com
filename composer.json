{
  "name": "localhost/wc8.5",
  "description": "Projeto migrado para Php 8.5",
  "autoload": {
    "psr-4": {
      "App\\": "_app/"
    },
    "files": [
      "_app/Config/bootstrap.php"
    ]
  },
  "require": {
    "league/glide": "^3.0.1",
    "phpmailer/phpmailer": "^6.10",
    "vlucas/phpdotenv": "^5.6",
    "php": "^8.5",
    "ext-fileinfo": "*"
  },
  "suggest": {
    "ext-gd": "One of ext-gd or ext-imagick is required for image manipulation with Glide.",
    "ext-imagick": "One of ext-imagick or ext-gd is required for image manipulation with Glide."
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "8.5.3"
    }
  },
  "scripts": {
    "stub": "/opt/homebrew/opt/php@8.5/bin/php bin/generate-constants-stub.php"
  }
}
